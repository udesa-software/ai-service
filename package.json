{
  "name": "ai-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "python3 -m venv api/.venv && api/.venv/bin/python -m pip install --upgrade pip && api/.venv/bin/python -m pip install -r api/requirements.txt",
    "check:venv": "test -x api/.venv/bin/python || (echo \"Missing ai-service virtualenv. Run: npm run setup\" && exit 1)",
    "pretest": "npm run check:venv",
    "test": "cd api && ./.venv/bin/python -m pytest tests/unit",
    "pretest:coverage": "npm run check:venv",
    "test:coverage": "cd api && ./.venv/bin/python -m pytest tests/unit --cov=src --cov-report=xml:coverage.xml",
    "pretest:integration": "npm run check:venv",
    "test:integration": "cd api && ./.venv/bin/python -m pytest tests/integration",
    "pretest:integration:coverage": "npm run check:venv",
    "test:integration:coverage": "cd api && ./.venv/bin/python -m pytest tests/integration --cov=main --cov=src --cov-report=xml:coverage-integration.xml"
  }
}
